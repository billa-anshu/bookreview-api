name: Keep Render Backend Alive

on:
  schedule:
    # Runs every 14 minutes (Render sleeps after 15)
    - cron: '*/14 * * * *'
  workflow_dispatch:  # Allows manual trigger

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Ping Render Backend
        run: |
          curl -I -s -o /dev/null -w "%{http_code}\n" https://bookreview-api-dqxd.onrender.com/api/health
